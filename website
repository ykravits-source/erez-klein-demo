<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ארז קליין – חשמלאי מוסמך</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;800;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#050C18;--navy:#0A1628;--navy2:#0E1F3D;--navy3:#132850;
  --yellow:#F5C518;--yellow2:#FFD740;--orange:#FF6B2B;--orange2:#FF8C55;
  --white:#FFFFFF;--grey:rgba(255,255,255,0.55);
  --border:rgba(245,197,24,0.15);
  --ease:cubic-bezier(0.23,1,0.32,1);
  --r:16px;
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:'Heebo',sans-serif;direction:rtl;text-align:right;background:var(--ink);color:#fff;overflow-x:hidden;cursor:none}
/* CURSOR */
#cur{position:fixed;width:10px;height:10px;background:var(--yellow);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .15s,height .15s;mix-blend-mode:difference}
#cur-r{position:fixed;width:34px;height:34px;border:1.5px solid rgba(245,197,24,.45);border-radius:50%;pointer-events:none;z-index:99998;transform:translate(-50%,-50%)}
body:has(a:hover) #cur,body:has(button:hover) #cur{width:20px;height:20px}
@media(max-width:768px){#cur,#cur-r{display:none}body{cursor:auto}}
/* NOISE */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.022;pointer-events:none;z-index:0}
/* NAV */
.nav{position:fixed;top:0;right:0;left:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:18px 5%;transition:all .4s var(--ease)}
.nav.scrolled{background:rgba(5,12,24,.93);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 5%}
.nav-logo{display:flex;align-items:center;gap:10px;font-size:1.1rem;font-weight:900;color:#fff;text-decoration:none}
.bolt-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--yellow),var(--orange));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;box-shadow:0 4px 16px rgba(245,197,24,.3);animation:bG 3s ease-in-out infinite}
@keyframes bG{0%,100%{box-shadow:0 4px 16px rgba(245,197,24,.3)}50%{box-shadow:0 4px 28px rgba(245,197,24,.65),0 0 50px rgba(245,197,24,.2)}}
.nav-r{display:flex;align-items:center;gap:14px}
.nav-links{display:flex;gap:26px;list-style:none}
.nav-links a{color:rgba(255,255,255,.6);font-size:.87rem;font-weight:600;text-decoration:none;transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;right:0;width:0;height:1.5px;background:var(--yellow);transition:width .3s var(--ease)}
.nav-links a:hover{color:#fff}.nav-links a:hover::after{width:100%}
.nav-wa{display:flex;align-items:center;gap:8px;background:#25D366;color:#fff;font-family:'Heebo',sans-serif;font-size:.85rem;font-weight:800;padding:10px 20px;border-radius:50px;text-decoration:none;transition:all .25s var(--ease);box-shadow:0 4px 18px rgba(37,211,102,.35)}
.nav-wa:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(37,211,102,.55)}
@media(max-width:640px){.nav-links{display:none}}
/* HERO */
.hero{min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;padding:130px 5% 80px;background:linear-gradient(150deg,var(--ink) 0%,#071228 55%,#0A1830 100%)}
#lc{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;opacity:.75}
.hg1{position:absolute;top:-20%;right:-10%;width:700px;height:700px;background:radial-gradient(circle,rgba(245,197,24,.07) 0%,transparent 65%);pointer-events:none;z-index:1;animation:gd1 8s ease-in-out infinite}
.hg2{position:absolute;bottom:-20%;left:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(255,107,43,.06) 0%,transparent 65%);pointer-events:none;z-index:1;animation:gd2 10s ease-in-out infinite}
@keyframes gd1{0%,100%{transform:translate(0,0)}50%{transform:translate(-40px,30px)}}
@keyframes gd2{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-40px)}}
.hgrid{position:absolute;inset:0;z-index:1;pointer-events:none;background-image:linear-gradient(rgba(245,197,24,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(245,197,24,.025) 1px,transparent 1px);background-size:80px 80px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 0%,transparent 100%)}
.hi{position:relative;z-index:2;max-width:760px}
.eyebrow{display:inline-flex;align-items:center;gap:10px;border:1px solid rgba(245,197,24,.3);background:rgba(245,197,24,.06);color:var(--yellow);font-size:.78rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:8px 18px;border-radius:50px;margin-bottom:32px;opacity:0;transform:translateY(20px);animation:fup .8s var(--ease) .2s forwards}
.ldot{width:7px;height:7px;background:var(--yellow);border-radius:50%;animation:lp 1.5s ease-in-out infinite;box-shadow:0 0 8px var(--yellow)}
@keyframes lp{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.5);opacity:.5}}
.hero h1{font-size:clamp(2.4rem,6vw,4.2rem);font-weight:900;line-height:1.1;letter-spacing:-1.5px;margin-bottom:26px;opacity:0;transform:translateY(30px);animation:fup .9s var(--ease) .4s forwards}
.h1-l1{display:block;color:#fff}
.h1-l2{display:block;background:linear-gradient(90deg,var(--yellow) 0%,var(--orange) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative}
.h1-l2::after{content:'';position:absolute;bottom:-6px;right:0;width:100%;height:3px;background:linear-gradient(90deg,var(--yellow),var(--orange));border-radius:2px;transform:scaleX(0);transform-origin:right;animation:ur 1s var(--ease) 1.3s forwards}
@keyframes ur{to{transform:scaleX(1)}}
.hero-sub{font-size:clamp(1rem,2.2vw,1.18rem);font-weight:400;color:rgba(255,255,255,.68);line-height:1.78;max-width:580px;margin-bottom:44px;opacity:0;transform:translateY(20px);animation:fup .9s var(--ease) .6s forwards}
.hero-sub strong{color:#fff;font-weight:800}
.htag{display:inline-block;background:rgba(245,197,24,.1);border:1px solid rgba(245,197,24,.25);color:var(--yellow);font-weight:800;font-size:.85em;padding:2px 10px;border-radius:4px;margin:0 2px}
.hbtns{display:flex;flex-wrap:wrap;gap:14px;opacity:0;transform:translateY(20px);animation:fup .9s var(--ease) .8s forwards}
@keyframes fup{to{opacity:1;transform:translateY(0)}}
.bwa{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#25D366,#1ab553);color:#fff;font-family:'Heebo',sans-serif;font-size:1.05rem;font-weight:800;padding:17px 34px;border-radius:50px;text-decoration:none;box-shadow:0 8px 28px rgba(37,211,102,.45);transition:all .3s var(--ease);position:relative;overflow:hidden}
.bwa::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);transform:translateX(-100%);transition:transform .4s var(--ease)}
.bwa:hover::before{transform:translateX(0)}.bwa:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 40px rgba(37,211,102,.6)}
.btel{display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.2);color:#fff;font-family:'Heebo',sans-serif;font-size:1rem;font-weight:700;padding:16px 28px;border-radius:50px;text-decoration:none;backdrop-filter:blur(8px);transition:all .3s var(--ease)}
.btel:hover{border-color:var(--yellow);color:var(--yellow);background:rgba(245,197,24,.08)}
.hscroll{position:absolute;bottom:38px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fup .6s var(--ease) 1.5s forwards}
.hscroll span{font-size:.7rem;color:rgba(255,255,255,.35);letter-spacing:2px;text-transform:uppercase}
.sline{width:1.5px;height:50px;background:linear-gradient(to bottom,rgba(245,197,24,.6),transparent);position:relative;overflow:hidden}
.sline::after{content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;background:var(--yellow);animation:ss 2s ease-in-out infinite}
@keyframes ss{0%{top:-100%}100%{top:200%}}
.hstats{position:absolute;left:5%;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:16px;z-index:2;opacity:0;animation:hsr 1s var(--ease) 1.1s forwards}
@keyframes hsr{to{opacity:1}}
.hstat{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);backdrop-filter:blur(20px);border-radius:14px;padding:18px 22px;min-width:160px;transition:all .3s var(--ease)}
.hstat:hover{background:rgba(245,197,24,.08);border-color:rgba(245,197,24,.3);transform:translateX(-6px)}
.hstat-num{font-size:1.8rem;font-weight:900;color:var(--yellow);line-height:1}
.hstat-lbl{font-size:.73rem;color:rgba(255,255,255,.45);margin-top:4px}
@media(max-width:1050px){.hstats{display:none}}
/* TRUST MARQUEE */
.tbar{background:var(--navy2);border-top:2.5px solid var(--yellow);border-bottom:1px solid rgba(245,197,24,.1);overflow:hidden;position:relative}
.tbar::before,.tbar::after{content:'';position:absolute;top:0;bottom:0;width:120px;z-index:2;pointer-events:none}
.tbar::before{right:0;background:linear-gradient(to left,var(--navy2),transparent)}
.tbar::after{left:0;background:linear-gradient(to right,var(--navy2),transparent)}
.mtrack{display:flex;align-items:center;animation:mq 28s linear infinite;white-space:nowrap}
.mtrack:hover{animation-play-state:paused}
@keyframes mq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.mi{display:inline-flex;align-items:center;gap:12px;padding:18px 40px;color:#fff;font-size:.88rem;font-weight:600;border-right:1px solid rgba(255,255,255,.07);flex-shrink:0}
.mi strong{color:var(--yellow);font-weight:800}
.mstars{color:var(--yellow);font-size:.9rem;letter-spacing:2px}
/* SECTION BASE */
section{padding:100px 5%;position:relative}
.slbl{display:inline-flex;align-items:center;gap:8px;font-size:.72rem;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;color:var(--orange);margin-bottom:12px}
.slbl::before{content:'';width:24px;height:2px;background:linear-gradient(90deg,var(--orange),transparent);display:inline-block}
.stitle{font-size:clamp(1.9rem,4.5vw,3rem);font-weight:900;line-height:1.15;letter-spacing:-1px;margin-bottom:16px;color:#fff}
.grad{background:linear-gradient(90deg,var(--yellow),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ssub{font-size:1.05rem;color:rgba(255,255,255,.58);line-height:1.75;max-width:560px}
.ssub strong{color:#fff;font-weight:800}
.cx{text-align:center}.cx .ssub,.cx .slbl{margin-left:auto;margin-right:auto;justify-content:center}
.mw{max-width:1100px;margin:0 auto}
/* SERVICES */
.svc-sec{background:var(--navy)}
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-top:56px}
.sc{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:var(--r);padding:32px 26px;position:relative;overflow:hidden;transition:all .4s var(--ease);cursor:default;opacity:0;transform:translateY(40px);perspective:800px}
.sc.rv{opacity:1;transform:translateY(0)}
.sc::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(245,197,24,.05),transparent);opacity:0;transition:opacity .4s}
.sc::after{content:'';position:absolute;top:0;right:0;left:0;height:2px;background:linear-gradient(90deg,var(--yellow),var(--orange));transform:scaleX(0);transform-origin:right;transition:transform .4s var(--ease)}
.sc:hover{background:rgba(245,197,24,.055);border-color:rgba(245,197,24,.25);box-shadow:0 20px 50px rgba(0,0,0,.4),0 0 40px rgba(245,197,24,.07)}
.sc:hover::before{opacity:1}.sc:hover::after{transform:scaleX(1)}
.si{width:60px;height:60px;background:linear-gradient(135deg,rgba(245,197,24,.12),rgba(255,107,43,.08));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:22px;border:1px solid rgba(245,197,24,.15);transition:all .4s var(--ease)}
.sc:hover .si{background:linear-gradient(135deg,rgba(245,197,24,.2),rgba(255,107,43,.15));transform:scale(1.1) rotate(-5deg);box-shadow:0 0 30px rgba(245,197,24,.45),0 0 60px rgba(245,197,24,.2)}
.sc h3{font-size:.98rem;font-weight:800;color:#fff;margin-bottom:10px;line-height:1.35}
.sc p{font-size:.84rem;color:rgba(255,255,255,.5);line-height:1.65}
.ebadge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,107,43,.1);border:1px solid rgba(255,107,43,.2);color:var(--orange2);font-size:.7rem;font-weight:800;padding:4px 12px;border-radius:50px;margin-top:14px;letter-spacing:.5px}
.blk{animation:blk .8s ease-in-out infinite}
@keyframes blk{0%,100%{opacity:1}50%{opacity:.25}}
/* TESTIMONIALS */
.tsec{background:var(--ink)}
.tgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:24px;margin-top:56px}
.tc{position:relative;border-radius:var(--r);padding:36px 32px;overflow:hidden;opacity:0;transform:translateY(50px) scale(.97);transition:all .6s var(--ease)}
.tc.rv{opacity:1;transform:translateY(0) scale(1)}
.tc-def{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1)}
.tc-def:hover{background:rgba(255,255,255,.07);border-color:rgba(245,197,24,.2);transform:translateY(-6px) scale(1.01);box-shadow:0 20px 50px rgba(0,0,0,.4)}
.tc-feat{background:linear-gradient(145deg,var(--navy2),var(--navy3));border:1px solid rgba(245,197,24,.2);box-shadow:0 0 60px rgba(245,197,24,.05),inset 0 0 60px rgba(245,197,24,.02)}
.tc-feat:hover{transform:translateY(-6px);box-shadow:0 24px 60px rgba(0,0,0,.5),0 0 80px rgba(245,197,24,.1);border-color:rgba(245,197,24,.4)}
.tc-feat::before{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(245,197,24,.04),transparent);transform:skewX(-20deg);animation:shine 5s ease-in-out infinite;z-index:0}
@keyframes shine{0%,100%{left:-100%}50%{left:150%}}
.tqi{position:absolute;top:16px;left:20px;font-size:7rem;line-height:1;font-family:Georgia,serif;color:rgba(245,197,24,.06);pointer-events:none;z-index:0;font-weight:900}
.tinn{position:relative;z-index:1}
.tstars{display:flex;gap:3px;margin-bottom:18px}
.tstars .st{font-size:1rem;color:var(--yellow)}
.ttext{font-size:1rem;font-weight:500;color:rgba(255,255,255,.88);line-height:1.8;margin-bottom:26px}
.ttext strong{color:var(--yellow);font-weight:900}
.ttext .em2{color:var(--orange);font-weight:900}
.trev{display:flex;align-items:center;gap:13px}
.tav{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--yellow),var(--orange));display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:900;color:var(--navy);flex-shrink:0;box-shadow:0 4px 16px rgba(245,197,24,.3)}
.tnm{font-size:.9rem;font-weight:800;color:#fff}
.tlc{font-size:.75rem;color:rgba(255,255,255,.4);margin-top:2px}
.gprf{display:inline-flex;align-items:center;gap:6px;font-size:.7rem;color:rgba(255,255,255,.3);border-top:1px solid rgba(255,255,255,.07);padding-top:14px;margin-top:14px}
/* PROCESS */
.proc{background:linear-gradient(150deg,#060E1C,var(--navy2));padding:80px 5%}
.psteps{display:flex;flex-wrap:wrap;gap:0;max-width:900px;margin:48px auto 0;position:relative}
.psteps::before{content:'';position:absolute;top:28px;right:10%;left:10%;height:2px;background:linear-gradient(90deg,var(--yellow),var(--orange),var(--yellow));background-size:200%;animation:fl 3s linear infinite}
@keyframes fl{0%{background-position:0%}100%{background-position:200%}}
@media(max-width:640px){.psteps::before{display:none}}
.ps{flex:1;min-width:180px;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 20px;opacity:0;transform:translateY(30px);transition:all .5s var(--ease)}
.ps.rv{opacity:1;transform:translateY(0)}
.sn{width:56px;height:56px;border-radius:50%;background:var(--navy);border:2px solid var(--yellow);display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:900;color:var(--yellow);margin-bottom:18px;position:relative;z-index:1;box-shadow:0 0 0 6px var(--navy2),0 0 20px rgba(245,197,24,.3);transition:all .3s}
.ps:hover .sn{background:var(--yellow);color:var(--navy);transform:scale(1.15);box-shadow:0 0 0 6px var(--navy2),0 0 40px var(--yellow)}
.stit{font-size:.92rem;font-weight:800;color:#fff;margin-bottom:6px}
.sdsc{font-size:.8rem;color:rgba(255,255,255,.43);line-height:1.5}
/* ABOUT */
.about-sec{background:var(--navy)}
.awrap{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
@media(max-width:850px){.awrap{grid-template-columns:1fr;gap:48px}}
.feat-list{list-style:none;display:flex;flex-direction:column;gap:14px;margin-top:28px}
.feat-list li{display:flex;align-items:center;gap:12px;font-size:.95rem;font-weight:600;color:rgba(255,255,255,.8)}
.chk{width:28px;height:28px;border-radius:8px;flex-shrink:0;background:linear-gradient(135deg,rgba(245,197,24,.18),rgba(255,107,43,.1));border:1px solid rgba(245,197,24,.18);display:flex;align-items:center;justify-content:center;font-size:.85rem;transition:all .3s}
.feat-list li:hover .chk{background:linear-gradient(135deg,var(--yellow),var(--orange));color:var(--navy);box-shadow:0 4px 16px rgba(245,197,24,.4);transform:scale(1.1)}
.svis{display:flex;flex-direction:column;gap:18px}
.sb{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:var(--r);padding:30px;display:flex;align-items:center;gap:22px;transition:all .4s var(--ease);opacity:0;transform:translateX(30px)}
.sb.rv{opacity:1;transform:translateX(0)}
.sb:hover{background:rgba(245,197,24,.06);border-color:rgba(245,197,24,.2);transform:translateX(-6px);box-shadow:0 12px 40px rgba(0,0,0,.3)}
.sb.gold{background:linear-gradient(135deg,var(--navy2),var(--navy3));border-color:rgba(245,197,24,.2)}
.se{font-size:2.2rem;flex-shrink:0}
.snum{font-size:2.4rem;font-weight:900;color:var(--yellow);line-height:1}
.sb.gold .snum{background:linear-gradient(90deg,var(--yellow),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sdlbl{font-size:.82rem;color:rgba(255,255,255,.45);margin-top:4px;line-height:1.4}
/* CTA */
.cta-s{padding:100px 5%;text-align:center;background:var(--ink);position:relative;overflow:hidden}
.cta-s::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:900px;background:radial-gradient(circle,rgba(245,197,24,.045) 0%,transparent 60%);pointer-events:none;animation:cg 6s ease-in-out infinite}
@keyframes cg{0%,100%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-50%) scale(1.1)}}
.cta-s .stitle{font-size:clamp(2rem,5vw,3.2rem);margin-bottom:12px}
.cbadges{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-bottom:44px;position:relative;z-index:1}
.cbadge{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:50px;padding:9px 18px;font-size:.82rem;font-weight:700;color:rgba(255,255,255,.73)}
.ydot{width:7px;height:7px;background:var(--yellow);border-radius:50%;box-shadow:0 0 8px var(--yellow)}
.bwa-cta{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#25D366,#1ab553);color:#fff;font-family:'Heebo',sans-serif;font-size:1.1rem;font-weight:800;padding:18px 38px;border-radius:50px;text-decoration:none;box-shadow:0 8px 28px rgba(37,211,102,.45);transition:all .3s var(--ease);position:relative;overflow:hidden;z-index:1}
.bwa-cta::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);transform:translateX(-100%);transition:transform .4s var(--ease)}
.bwa-cta:hover::before{transform:translateX(0)}.bwa-cta:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 40px rgba(37,211,102,.6)}
/* FOOTER */
footer{background:var(--navy2);border-top:2px solid rgba(245,197,24,.15);padding:60px 5% 36px;text-align:center}
