}
const cio=new IntersectionObserver(es=>es.forEach(e=>{if(!e.isIntersecting)return;e.target.querySelectorAll('[data-count]').forEach(countUp);cio.unobserve(e.target)}),{threshold:.3});
document.querySelectorAll('.svis').forEach(el=>cio.observe(el));

/* ── 3D Card Tilt ── */
document.querySelectorAll('.sc').forEach(c=>{
