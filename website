const cur=document.getElementById('cur'),curR=document.getElementById('cur-r');
let mx=-100,my=-100,rx=-100,ry=-100;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function ac(){cur.style.left=mx+'px';cur.style.top=my+'px';rx+=(mx-rx)*.11;ry+=(my-ry)*.11;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(ac)})();

/* ── Navbar ── */
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',scrollY>50),{passive:true});

/* ── Lightning Canvas ── */
(()=>{
  const canvas=document.getElementById('lc'),ctx=canvas.getContext('2d');
  let W,H;
  const resize=()=>{W=canvas.width=canvas.offsetWidth;H=canvas.height=canvas.offsetHeight};
  resize();window.addEventListener('resize',resize);

  function bolt(x1,y1,x2,y2,d=0){
    if(d>5)return[[x1,y1,x2,y2]];
    const mx=(x1+x2)/2+(Math.random()-.5)*90*(1-d*.15),my=(y1+y2)/2+(Math.random()-.5)*45*(1-d*.15);
    return[...bolt(x1,y1,mx,my,d+1),...bolt(mx,my,x2,y2,d+1)];
  }
  class Spark{
    constructor(){this.reset();this.life=Math.random()*50}
    reset(){this.x=Math.random()*W;this.y=Math.random()*H*.55;this.life=0;this.maxLife=35+Math.random()*45;this.segs=bolt(this.x,this.y,this.x+(Math.random()-.5)*220,this.y+100+Math.random()*220)}
    draw(){
      const a=Math.sin(Math.PI*this.life/this.maxLife)*.5;
      ctx.save();ctx.strokeStyle=`rgba(245,197,24,${a})`;ctx.lineWidth=1.3;ctx.shadowColor='rgba(245,197,24,.8)';ctx.shadowBlur=10;ctx.beginPath();
      this.segs.forEach(([x1,y1,x2,y2])=>{ctx.moveTo(x1,y1);ctx.lineTo(x2,y2)});
      ctx.stroke();ctx.restore();this.life++;if(this.life>=this.maxLife)this.reset();
    }
  }
  const sparks=Array.from({length:4},()=>new Spark());
  const pts=Array.from({length:50},()=>({x:Math.random()*1e4,y:Math.random()*1e4,r:.4+Math.random()*1.2,vx:(Math.random()-.5)*.35,vy:-.15-Math.random()*.55,a:.08+Math.random()*.35}));

  let frame=0;
  function draw(){
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      ctx.save();ctx.beginPath();ctx.arc(p.x%W,p.y%H,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(245,197,24,${p.a})`;ctx.fill();ctx.restore();
      p.x=(p.x+p.vx*W/1e4*W+W)%W;p.y=(p.y+p.vy*H/1e4*H+H)%H;
    });
    if(frame%3===0)sparks.forEach(s=>s.draw());
    else sparks.forEach(s=>{s.life+=.4;if(s.life>=s.maxLife)s.reset()});
    frame++;requestAnimationFrame(draw);
  }
  draw();
})();

